# Copy to frontend/.env and fill in for a public web deployment.
# Leave unset (or delete .env) for the desktop/exe build — then no ads load.

# AdSense publisher id (from your AdSense account), e.g. ca-pub-1234567890123456
VITE_ADSENSE_CLIENT=

# A display ad unit's slot id (10-digit), e.g. 1234567890
VITE_ADSENSE_SLOT=
