# --- Python ---
__pycache__/
*.pyc
.venv/
venv/

# --- Node / frontend ---
node_modules/
frontend/.env

# --- Build artifacts ---
# PyInstaller work dir
build_exe/
*.spec.bak
pyinstaller*.log

# --- Runtime / transient data ---
backend/downloads/
backend/data/
# per-run audio scratch beside the exe
dist_exe/data/
dist_exe/run.*
dist_exe/*.log
**/browser-profile/

# --- OS ---
Thumbs.db
.DS_Store

# --- Large binaries: shipped via GitHub Releases, not committed ---
dist_exe/*.exe
# icon preview (regenerated by assets/make_icon.py)
assets/app_preview.png

# NOTE: the exe is distributed as a GitHub Release asset (see README). The repo
# keeps everything needed to rebuild it (backend/desktop_app.py, the .spec,
# assets/app.ico) plus the small frontend/dist so build_exe.bat works offline.
